# ============================================================================
# Railway — Environment Variables cho service WEB (Next.js)
# Dán vào: service `web` → tab Variables → Raw Editor → Paste.
#
# ⚠️ NEXT_PUBLIC_* được "nướng" lúc BUILD → PHẢI ghi DOMAIN THẬT của service api
#    (KHÔNG dùng ${{api.RAILWAY_PUBLIC_DOMAIN}} — tham chiếu chéo KHÔNG resolve
#    lúc build, sẽ bake ra "https://" rỗng). Sau khi sửa phải REDEPLOY web.
# ============================================================================

# Thay bằng domain thật của service api (Settings → Networking → domain đã generate):
NEXT_PUBLIC_BACKEND_URL=https://<api-domain>.up.railway.app
API_INTERNAL_URL=https://<api-domain>.up.railway.app
NEXT_PUBLIC_DEFAULT_FUNNEL_SLUG=
