# ============================================================================
# Railway — Environment Variables cho service WEB (Next.js)
# Dán KHỐI NÀY vào: service `web` → tab Variables → nút "Raw Editor" → Paste.
#
# - `${{api.RAILWAY_PUBLIC_DOMAIN}}` trỏ tới service API — giữ nguyên (service
#   API phải đặt ĐÚNG TÊN `api`).
# - NEXT_PUBLIC_* được "nướng" lúc BUILD → sau khi set phải REDEPLOY service web.
# ============================================================================

NEXT_PUBLIC_BACKEND_URL=https://${{api.RAILWAY_PUBLIC_DOMAIN}}
API_INTERNAL_URL=https://${{api.RAILWAY_PUBLIC_DOMAIN}}
NEXT_PUBLIC_DEFAULT_FUNNEL_SLUG=
