# ============================================================================
# Railway — Environment Variables cho service API (FastAPI)
# Dán KHỐI NÀY vào: service `api` → tab Variables → nút "Raw Editor" → Paste.
#
# - `${{...}}` là THAM CHIẾU Railway — giữ nguyên, Railway tự thay khi deploy.
#   (Yêu cầu service khác đặt ĐÚNG TÊN: Postgres = `Postgres`, web = `web`.)
# - Dòng để trống = tính năng đó tắt (app vẫn chạy).
# ============================================================================

# ---- Bắt buộc ----
DATABASE_URL=${{Postgres.DATABASE_URL}}
SECRET_KEY=THAY_BANG_CHUOI_NGAU_NHIEN   # tạo: openssl rand -hex 32

# ---- CORS + link email/checkout (trỏ tới service web) ----
ALLOWED_ORIGINS=https://${{web.RAILWAY_PUBLIC_DOMAIN}}
FRONTEND_URL=https://${{web.RAILWAY_PUBLIC_DOMAIN}}

# ---- Media: Cloudflare R2 (tùy chọn) ----
STORAGE_ENDPOINT=
STORAGE_BUCKET=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_REGION=auto
STORAGE_PUBLIC_URL=

# ---- Email: Resend (tùy chọn) ----
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# ---- Thanh toán: SePay/VietQR (tùy chọn) ----
SEPAY_BANK_NAME=
SEPAY_ACCOUNT_NUMBER=

# ---- Tracking: Meta CAPI (tùy chọn) ----
META_DEFAULT_PIXEL_ID=
META_DEFAULT_CAPI_TOKEN=
